# Postgres
POSTGRES_USER=yt2tt
POSTGRES_PASSWORD=yt2tt
POSTGRES_DB=yt2tt
DATABASE_URL=postgresql+asyncpg://yt2tt:yt2tt@postgres:5432/yt2tt

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# S3 (set to empty to skip upload in dev)
S3_BUCKET=
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PRESIGN_EXPIRES=86400

# Media workdir (inside container)
MEDIA_DIR=/tmp/yt2tt

# App
APP_ENV=dev
APP_CORS_ORIGINS=http://localhost:3000

# TikTok Content Posting API v2 (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish
TIKTOK_POST_CONNECT_REDIRECT=http://localhost:3000

# Fernet key for encrypting stored OAuth tokens.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
